{
    "name": "jpipe-extension",
    "displayName": "jPipe Language (McSCert)",
    "description": "Language Support for the jPipe language",
    "version": "1.0.3",
    "type": "module",
    "publisher": "mcscert",
    "author": "McMaster Centre for Software Certification (McSCert)",
    "license": "MIT",
    "icon": "images/logo.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/jpipe-mcscert/jpipe-vscode"
    },
    "engines": {
        "vscode": "^1.67.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "configurationDefaults": {
            "[jpipe]": {
                "editor.wordBasedSuggestions": "off"
            }
        },
        "languages": [
            {
                "id": "jpipe",
                "aliases": [
                    "jpipe",
                    "jpipe"
                ],
                "extensions": [
                    ".jd"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "dark": "images/icon_dark.svg",
                    "light": "images/icon_light.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "jpipe",
                "scopeName": "source.jpipe",
                "path": "syntaxes/jpipe.tmLanguage.json"
            }
        ],
        "semanticTokenTypes": [
            {
                "id": "jpipe-load",
                "superType": "namespace",
                "description": "Import keyword (load)"
            },
            {
                "id": "jpipe-structure",
                "superType": "type",
                "description": "Structural keywords (justification, template, implements)"
            },
            {
                "id": "jpipe-relation",
                "superType": "keyword",
                "description": "Relation keyword (supports)"
            },
            {
                "id": "jpipe-abstract",
                "superType": "keyword",
                "description": "Abstract element keyword (@support)"
            },
            {
                "id": "jpipe-element",
                "superType": "keyword",
                "description": "Element keywords (conclusion, evidence, strategy, sub-conclusion)"
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "jpipe",
                "scopes": {
                    "jpipe-load": ["entity.name.namespace.jpipe"],
                    "jpipe-structure": ["support.type.jpipe"],
                    "jpipe-relation": ["variable.other.enummember.jpipe"],
                    "jpipe-abstract": ["storage.modifier.jpipe"],
                    "jpipe-element": ["entity.name.function.jpipe"]
                }
            }
        ],
        "commands": [
            {
                "command": "jpipe.vis.preview",
                "title": "Open Diagram Preview",
                "category": "jPipe",
                "icon": "$(open-preview)"
            },
            {
                "command": "jpipe.downloadSVG",
                "title": "Download as SVG",
                "category": "jPipe",
                "icon": "$(save)"
            },
            {
                "command": "jpipe.downloadPNG",
                "title": "Download as PNG",
                "category": "jPipe",
                "icon": "$(save)"
            },
            {
                "command": "jpipe.downloadJSON",
                "title": "Download as JSON",
                "category": "jPipe",
                "icon": "$(save)"
            },
            {
                "command": "jpipe.downloadJPEG",
                "title": "Download as JPEG",
                "category": "jPipe",
                "icon": "$(save)"
            },
            {
                "command": "jpipe.downloadDOT",
                "title": "Download as DOT",
                "category": "jPipe",
                "icon": "$(save)"
            },
            {
                "command": "jpipe.downloadPython",
                "title": "Download as Python",
                "category": "jPipe",
                "icon": "$(save)"
            },
            {
                "command": "jpipe.downloadJPIPE",
                "title": "Download as jPipe",
                "category": "jPipe",
                "icon": "$(save)"
            },
            {
                "command": "jpipe.checkInstallation",
                "title": "Check jPipe Installation",
                "category": "jPipe",
                "icon": "$(check)"
            },
            {
                "command": "jpipe.addExcludedDirectory",
                "title": "Add Excluded Directory",
                "category": "jPipe",
                "icon": "$(folder-opened)"
            }
        ],
        "submenus": [
            {
                "id": "jpipe.submenu",
                "label": "jPipe"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "jpipe.vis.preview",
                    "when": "resourceLangId == jpipe",
                    "group": "navigation@0"
                }
            ],
            "editor/context": [
                {
                    "submenu": "jpipe.submenu",
                    "when": "resourceLangId == jpipe",
                    "group": "navigation"
                }
            ],
            "jpipe.submenu": [
                {
                    "command": "jpipe.vis.preview",
                    "group": "1_view@1"
                },
                {
                    "command": "jpipe.downloadSVG",
                    "group": "2_download@1"
                },
                {
                    "command": "jpipe.downloadPNG",
                    "group": "2_download@2"
                },
                {
                    "command": "jpipe.downloadJSON",
                    "group": "2_download@3"
                },
                {
                    "command": "jpipe.downloadJPEG",
                    "group": "2_download@4"
                },
                {
                    "command": "jpipe.downloadDOT",
                    "group": "2_download@5"
                },
                {
                    "command": "jpipe.downloadPython",
                    "group": "2_download@6"
                },
                {
                    "command": "jpipe.downloadJPIPE",
                    "group": "2_download@7"
                }
            ]
        },
        "configuration": {
            "title": "jPipe",
            "properties": {
                "jpipe.executionMode": {
                    "order": 1,
                    "type": "string",
                    "enum": [
                        "cli",
                        "jar"
                    ],
                    "enumDescriptions": [
                        "Use the jpipe CLI executable (recommended). Configure the path below with 'CLI: Path'.",
                        "Use a JAR file (manual installation / developer mode). Configure the path below with 'JAR: File' and 'JAR: Java Executable'."
                    ],
                    "default": "cli",
                    "markdownDescription": "How to invoke the jPipe compiler. Choose **cli** (recommended) or **jar** (manual installation).\n\n[Check jPipe installation](command:jpipe.checkInstallation)"
                },
                "jpipe.cliPath": {
                    "order": 2,
                    "type": "string",
                    "default": "jpipe",
                    "markdownDescription": "**[cli mode only]** Path to the `jpipe` CLI executable. Accepts a bare name (resolved via `PATH`), a relative path, or an absolute path."
                },
                "jpipe.jarFile": {
                    "order": 3,
                    "type": "string",
                    "default": "",
                    "markdownDescription": "**[jar mode only]** Absolute path to the `jpipe` JAR file."
                },
                "jpipe.javaExecutable": {
                    "order": 4,
                    "type": "string",
                    "default": "java",
                    "markdownDescription": "**[jar mode only]** Path to the `java` executable used to run the JAR. Defaults to `java` (resolved via `PATH`)."
                },
                "jpipe.logLevel": {
                    "order": 5,
                    "type": "string",
                    "enum": [
                        "off",
                        "error",
                        "warn",
                        "info",
                        "debug",
                        "trace"
                    ],
                    "enumDescriptions": [
                        "No logging.",
                        "Errors only.",
                        "Errors and warnings.",
                        "Errors, warnings, and key lifecycle events (default).",
                        "Detailed operational info (commands, renders, imports).",
                        "Everything, including per-cursor and per-completion events."
                    ],
                    "default": "info",
                    "description": "Verbosity of the jPipe log channel (Output > jPipe). The language server log level (Output > jPipe Language Server) is set once at startup and requires a window reload to change."
                },
                "jpipe.excludedDirectories": {
                    "order": 6,
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "markdownDescription": "Directories (relative to workspace root) whose `.jd` files are excluded from validation. Files in excluded directories display a warning instead of errors. Changes require a window reload to take effect.\n\n[$(folder-opened) Browse for directory…](command:jpipe.addExcludedDirectory)"
                }
            }
        }
    },
    "activationEvents": [
        "onLanguage:jpipe"
    ],
    "main": "./out/extension/main.cjs",
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out syntaxes",
        "vscode:prepublish": "npm run build",
        "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/jpipe.tmLanguage.json ./syntaxes/jpipe.tmLanguage.json",
        "build": "npm run build:prepare && tsc -b tsconfig.json && node esbuild.mjs",
        "build:clean": "npm run clean && npm run build",
        "watch": "npm run build:prepare && concurrently -n tsc,esbuild -c blue,yellow \"tsc -b tsconfig.json --watch\" \"node esbuild.mjs --watch\""
    },
    "dependencies": {
        "jpipe-language": "1.0.3",
        "vscode-languageclient": "~9.0.1",
        "vscode-languageserver": "~9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "~1.67.0",
        "concurrently": "~8.2.1"
    },
    "vsce": {
        "dependencies": false
    }
}

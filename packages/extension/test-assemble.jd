// Test the assemble operator with your example
// assemble expects 2 arguments: strategy and conclusion

template T {
    evidence e1 is "e1"
    strategy s2 is "s"
    conclusion c2 is "c"
    e1 supports s2
    s2 supports c2
}

// Original version using implements - should still work
justification J implements T {
    evidence extra is "extra"
    extra supports s2
}

// Extended version using assemble operator
// assemble(s2, c2) - passes strategy s2 and conclusion c2 as arguments
justification J1 is assemble(s2, c2) {
    strategy s2 is "my strategy"
    conclusion c2 is "my conclusion"
    evidence extra is "extra evidence"
    extra supports s2
}

// Another example using assemble with different argument names
justification J2 is assemble(myStrategy, myConclusion) {
    strategy myStrategy is "strategy"
    conclusion myConclusion is "conclusion"
    evidence e is "evidence"
    e supports myStrategy
    myStrategy supports myConclusion
}

// This should ERROR: missing argument 's2' in justification body
justification J3 is assemble(s2, c2) {
    // Missing s2 - only c2 is defined
    conclusion c2 is "conclusion"
}

// This should ERROR: missing argument 'missing' in justification body
justification J4 is assemble(myStrategy, missing) {
    strategy myStrategy is "strategy"
    // missing is not defined anywhere
}
